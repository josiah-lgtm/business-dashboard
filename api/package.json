{
  "name": "business-dashboard-api",
  "version": "1.0.0",
  "private": true,
  "description": "Postgres-backed sync + reporting backend for business-dashboard",
  "type": "module",
  "scripts": {
    "prisma:generate": "prisma generate",
    "migrate:dev": "prisma migrate dev",
    "migrate:deploy": "prisma migrate deploy",
    "build": "prisma generate && tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "seed": "tsx scripts/seed.ts",
    "import": "tsx scripts/seed.ts",
    "migrate-from-tracker": "tsx scripts/migrate-from-tracker.ts",
    "test": "node --import tsx --test src/merge.test.ts src/serialize.test.ts"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@prisma/client": "^6.2.1",
    "fastify": "^5.2.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "prisma": "^6.2.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
