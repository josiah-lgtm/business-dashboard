# Copy to `.env` and fill in. `.env` is gitignored — never commit real secrets.
# Generate secrets with: openssl rand -hex 32

# --- Postgres ---
POSTGRES_USER=bdash
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=business_dashboard

# --- Published host ports (bound to 127.0.0.1 only) ---
WEB_PORT=54331
API_PORT=54330
DB_PORT=54329

# --- API write token ---
# The nginx proxy injects this as `Authorization: Bearer <token>`; the api
# enforces it. The browser never sees it. Required in production.
API_TOKEN=change-me-64-hex-token

# Upstream the web proxy forwards to (compose network), and CORS allow-list for
# the direct/dev path (Vite on :5173 hitting the api directly).
API_UPSTREAM=http://api:3000
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://businessdashboard.agencyadvanta.com

# --- Baked into the SPA at build time (safe to expose) ---
VITE_API_URL=/api/external/kv
# The ONE shared workspace both users land in (so Josiah + Joanna sync together).
VITE_WORKSPACE_KEY=bd-agencyadvanta-shared

# --- Dev only — leave UNSET in production (would expose the token in the bundle) ---
# VITE_API_TOKEN=
